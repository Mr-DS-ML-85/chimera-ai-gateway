# CrowdSec Environment Variables
# Copy to .env and customize

# CrowdSec Local API Password (auto-generated on first run)
CROWDSEC_LOCAL_API_PASSWORD=changemechangeme

# CrowdSec API Key for bouncer (generate with: docker exec chimera_crowdsec cscli bouncer add fail2ban-bouncer)
CROWDSEC_API_KEY=changeme

# Timezone
TZ=UTC